@{
    ViewData["Title"] = "Hakkımızda";
}

<section class="about-hero-fancy">
    <div class="container text-center position-relative">
        <h1 class="display-3 fw-800 mb-4">Teknolojiyle Hayat <br>Kurtarıyoruz.</h1>
        <p class="lead opacity-75 mx-auto" style="max-width: 800px; font-weight: 500;">
            Odak, yapay zeka ve derin öğrenme teknolojilerini yol güvenliğinin merkezine koyan inovatif bir mühendislik
            girişimidir.
        </p>
    </div>
</section>

<section class="container py-5 my-5">
    <div class="row g-5 align-items-center">
        <div class="col-lg-6">
            <div class="about-card">
                <span class="feature-tag">Biz Kimiz?</span>
                <h2 class="fw-800 mb-4 text-dark">Güvenli Sürüşün <br><span class="text-primary">Dijital Kalkanı</span>
                </h2>
                <p class="text-muted fs-5 mb-4" style="text-align: justify;">
                    Odak projesi, dünya genelinde trafik kazalarının %20'sinden fazlasının yorgunluk ve uykusuzluktan
                    kaynaklandığı gerçeği üzerine kuruldu. Biz, sadece bir yazılım değil, sürücünün en zor anlarında
                    yanında olan akıllı bir "yardımcı pilot" inşa ediyoruz.
                </p>
                <p class="text-muted mb-4" style="text-align: justify;">
                    Geliştirdiğimiz teknoloji; karmaşık yüz mimiklerini, göz bebeği hareketlerini ve baş pozisyonlarını
                    eş zamanlı analiz ederek, insan duyularının fark edemeyeceği mikro-uyku belirtilerini henüz
                    başlangıç aşamasında tespit eder.
                </p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-primary me-2"></i>
                            <span class="fw-700">7/24 Aktif Analiz</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-primary me-2"></i>
                            <span class="fw-700">Yüksek Doğruluk</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=800"
                class="img-fluid rounded-5 shadow-lg" alt="Team Work">
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container py-5">
        <div class="row mb-5 text-center">
            <div class="col-lg-8 mx-auto">
                <h2 class="fw-800 display-5">Neden Odak?</h2>
                <p class="text-muted mt-3">Sektörel standartları belirleyen üç temel sütunumuz.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="value-card h-100">
                    <div class="icon-box mb-3">
                        <i class="bi bi-lightbulb text-primary fs-3"></i>
                    </div>
                    <h4 class="fw-800">İnovasyon</h4>
                    <p class="text-muted small mb-0">Geleneksel sensörler yerine, bilgisayarlı görü (Computer Vision)
                        tekniklerini kullanarak ek bir donanıma ihtiyaç duymadan çalışıyoruz.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="value-card h-100">
                    <div class="icon-box mb-3">
                        <i class="bi bi-phone text-primary fs-3"></i>
                    </div>
                    <h4 class="fw-800">Erişilebilirlik</h4>
                    <p class="text-muted small mb-0">Karmaşık sistemleri her sürücünün kullanabileceği kadar basit bir
                        arayüzle, web ve mobil platformlara entegre ediyoruz.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="value-card h-100">
                    <div class="icon-box mb-3">
                        <i class="bi bi-shield-lock text-primary fs-3"></i>
                    </div>
                    <h4 class="fw-800">Veri Gizliliği</h4>
                    <p class="text-muted small mb-0">Kullanıcı güvenliği kadar veri gizliliğine de önem veriyoruz.
                        Görüntüleri kaydetmiyor, sadece anlık analiz verilerini işliyoruz.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5 my-5">
    <div class="row g-4">
        <div class="col-md-6">
            <div class="about-card h-100" style="background: #eff6ff;">
                <h3 class="fw-800 text-primary mb-3"><i class="bi bi-bullseye me-2"></i>Misyonumuz</h3>
                <p class="fs-5 text-dark" style="text-align: justify;">
                    Yapay zeka teknolojisini demokratikleştirerek, ticari araçlardan bireysel kullanıcılara kadar
                    herkesin sürüş güvenliğini en üst seviyeye taşımak ve uykusuzluk kaynaklı can kayıplarını tarihe
                    karıştırmak.
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="about-card h-100 border">
                <h3 class="fw-800 text-dark mb-3"><i class="bi bi-eye me-2 text-primary"></i>Vizyonumuz</h3>
                <p class="fs-5 text-muted" style="text-align: justify;">
                    Otonom sürüş dünyasına giden yolda, insan-araç etkileşimini en güvenli hale getiren küresel bir
                    standart haline gelmek ve her yeni araçta "Odak" imzasını bulundurmak.
                </p>
            </div>
        </div>
    </div>
</section>

