@{
    ViewData["Title"] = "Küresel Trafik İstatistikleri";
}

<section class="stats-header py-5 bg-white border-bottom">
    <div class="container text-center">
        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill fw-bold mb-3">KÜRESEL RAPOR 2024</span>
        <h1 class="fw-800 display-5 mb-3 text-dark">Trafik Güvenliği <span class="text-primary">Gerçekleri</span></h1>
        <p class="lead text-muted mx-auto" style="max-width: 800px;">
            Dünya genelindeki trafik kazalarının perde arkasındaki "görünmez tehlike" yorgunluktur. 
            Aşağıdaki veriler, ODAK projesinin çözüm üretmeyi hedeflediği küresel sorunun boyutunu göstermektedir.
        </p>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="p-4 rounded-4 shadow-sm h-100 border bg-white position-relative overflow-hidden card-hover-effect">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-danger text-white rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted fw-bold small mb-0 text-uppercase">YILLIK CAN KAYBI</h6>
                        <span class="text-dark fw-800 fs-4">1.19 Milyon</span>
                    </div>
                </div>
                <p class="text-muted small mb-0 border-top pt-3">
                    Dünya Sağlık Örgütü (WHO) verilerine göre her yıl trafik kazalarında hayatını kaybeden insan sayısı.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 rounded-4 shadow-sm h-100 border bg-white position-relative overflow-hidden card-hover-effect">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-eye-slash-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted fw-bold small mb-0 text-uppercase">YORGUNLUK ETKİSİ</h6>
                        <span class="text-dark fw-800 fs-4">%20 - %25</span>
                    </div>
                </div>
                <p class="text-muted small mb-0 border-top pt-3">
                    Tüm ölümlü kazaların yaklaşık dörtte biri doğrudan sürücü yorgunluğu ve dikkat dağınıklığı kaynaklıdır.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 rounded-4 shadow-sm h-100 border bg-white position-relative overflow-hidden card-hover-effect">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning text-white rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-moon-stars-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted fw-bold small mb-0 text-uppercase">GECE RİSKİ</h6>
                        <span class="text-dark fw-800 fs-4">3 Kat Fazla</span>
                    </div>
                </div>
                <p class="text-muted small mb-0 border-top pt-3">
                    Gece sürüşlerinde ölümcül kaza riski, gündüz sürüşlerine oranla 3 kat daha fazladır.
                </p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="p-4 rounded-4 shadow-sm border bg-white h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h5 class="fw-800 m-0 text-dark">Biyolojik Saat ve Kaza Riski</h5>
                        <p class="text-muted small mb-0">İnsan biyolojisine göre kaza riskinin en yüksek olduğu saatler</p>
                    </div>
                </div>
                
                <div class="chart-container" style="position: relative; height: 350px;">
                    <canvas id="riskTrendChart"></canvas>
                </div>
                
                <div class="mt-3 p-3 bg-light rounded-3 d-flex align-items-start gap-2">
                    <i class="bi bi-info-circle-fill text-primary mt-1"></i>
                    <p class="small text-muted mb-0">
                        Grafik, insan vücudunun uykuya en meyilli olduğu "Ölümcül Saatler"i göstermektedir. 
                        <strong>02:00 - 06:00</strong> arası derin uyku ihtiyacı, <strong>14:00 - 16:00</strong> arası ise "Öğle Sonrası Çöküşü" olarak adlandırılır.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="p-4 rounded-4 shadow-sm border bg-white h-100">
                <h5 class="fw-800 mb-2 text-center text-dark">Kaza Dağılımı</h5>
                <p class="text-center text-muted small mb-4">Araç türlerine göre küresel kaza karışım oranları</p>
                
                <div class="chart-container" style="position: relative; height: 300px;">
                    <canvas id="vehicleTypeChart"></canvas>
                </div>

                <div class="mt-4">
                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                        <span class="small fw-bold text-muted">Binek Araçlar</span>
                        <span class="badge bg-primary rounded-pill">%64</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                        <span class="small fw-bold text-muted">Ağır Vasıta (TIR/Kamyon)</span>
                        <span class="badge bg-dark rounded-pill">%16</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                        <span class="small fw-bold text-muted">Motosiklet</span>
                        <span class="badge bg-info text-dark rounded-pill">%12</span>
                    </div>
                    <div class="mt-3 text-center">
                        <small class="text-muted fst-italic" style="font-size: 0.75rem;">* Ağır vasıta kazalarında ölüm oranı binek araçlara göre <strong>8 kat</strong> daha yüksektir.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .card-hover-effect {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .card-hover-effect:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ctx1 = document.getElementById('riskTrendChart').getContext('2d');
    
    let gradientRisk = ctx1.createLinearGradient(0, 0, 0, 400);
    gradientRisk.addColorStop(0, 'rgba(220, 53, 69, 0.4)');
    gradientRisk.addColorStop(1, 'rgba(220, 53, 69, 0.0)');

    new Chart(ctx1, {
        type: 'line',
        data: {
            labels: ['00:00', '02:00', '04:00', '06:00', '08:00', '10:00', '12:00', '14:00', '16:00', '18:00', '20:00', '22:00'],
            datasets: [{
                label: 'Kaza Riski Seviyesi',
                data: [60, 85, 95, 80, 40, 20, 25, 65, 55, 30, 40, 50], 
                borderColor: '#dc3545',
                backgroundColor: gradientRisk,
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#dc3545',
                pointBorderWidth: 2,
                pointRadius: 4
            }]
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100,
                    grid: { color: '#f8f9fa' },
                    ticks: { display: false }
                },
                x: {
                    grid: { display: false }
                }
            },
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return 'Risk Seviyesi: %' + context.parsed.y;
                        }
                    }
                }
            }
        }
    });

    const ctx2 = document.getElementById('vehicleTypeChart').getContext('2d');
    new Chart(ctx2, {
        type: 'doughnut',
        data: {
            labels: ['Binek Araç', 'Ağır Vasıta', 'Motosiklet', 'Diğer'],
            datasets: [{
                data: [64, 16, 12, 8],
                backgroundColor: [
                    '#0d6efd',
                    '#212529',
                    '#0dcaf0',
                    '#ced4da'
                ],
                borderWidth: 0,
                hoverOffset: 8
            }]
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true,
                        padding: 20,
                        font: { size: 11 }
                    }
                }
            }
        }
    });
</script>